{
  "name": "vscode-repo-stats",
  "displayName": "Repo Stats",
  "description": "Visualize repository statistics with contributor dashboards, code frequency graphs, and treemap views",
  "version": "1.4.1",
  "publisher": "guwidoe",
  "license": "MIT",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "git",
    "repository",
    "statistics",
    "contributors",
    "visualization",
    "treemap",
    "loc",
    "code frequency"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/guwidoe/vscode-repo-stats"
  },
  "homepage": "https://github.com/guwidoe/VSCode-repo-stats#readme",
  "bugs": {
    "url": "https://github.com/guwidoe/VSCode-repo-stats/issues"
  },
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.git",
    "onCommand:repoStats.showDashboard",
    "onCommand:repoStats.refreshStats",
    "onCommand:repoStats.selectRepository",
    "onCommand:repoStats.addRepository"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "repoStats.showDashboard",
        "title": "Repo Stats: Show Dashboard"
      },
      {
        "command": "repoStats.refreshStats",
        "title": "Repo Stats: Refresh"
      },
      {
        "command": "repoStats.selectRepository",
        "title": "Repo Stats: Select Repositories"
      },
      {
        "command": "repoStats.addRepository",
        "title": "Repo Stats: Add Repository"
      }
    ],
    "configuration": {
      "title": "Repo Stats",
      "properties": {
        "repoStats.excludePatterns": {
          "type": "array",
          "scope": "resource",
          "default": [],
          "description": "Additional file or folder exclude patterns beyond .gitignore (e.g. vendor, backend/fixtures, /src, /README.md, **/fixtures/**)"
        },
        "repoStats.maxCommitsToAnalyze": {
          "type": "number",
          "scope": "resource",
          "default": 10000,
          "description": "Maximum commits to analyze (performance limit for large repos)"
        },
        "repoStats.defaultColorMode": {
          "type": "string",
          "enum": [
            "language",
            "age",
            "complexity",
            "density"
          ],
          "default": "language",
          "description": "Default treemap color mode"
        },
        "repoStats.generatedPatterns": {
          "type": "array",
          "scope": "resource",
          "default": [
            "**/generated/**",
            "**/gen/**",
            "**/__generated__/**",
            "**/dist/**",
            "**/build/**",
            "**/*.generated.*",
            "**/*.g.ts",
            "**/*.g.js",
            "**/*.g.dart",
            "**/*.gen.ts",
            "**/*.gen.js",
            "**/*.pb.go",
            "**/*.pb.ts",
            "**/*.pb.js",
            "**/*.graphql.ts",
            "**/*.graphql.js",
            "**/*_generated.*",
            "**/*.min.js",
            "**/*.min.css",
            "**/*.bundle.js",
            "**/*.bundle.css",
            "**/package-lock.json",
            "**/yarn.lock",
            "**/pnpm-lock.yaml",
            "**/*-lock.*"
          ],
          "description": "Glob patterns to identify generated files (flagged in file metadata and overview stats)"
        },
        "repoStats.binaryExtensions": {
          "type": "array",
          "scope": "resource",
          "default": [
            ".png",
            ".jpg",
            ".jpeg",
            ".gif",
            ".ico",
            ".webp",
            ".bmp",
            ".tiff",
            ".tif",
            ".psd",
            ".ai",
            ".eps",
            ".raw",
            ".cr2",
            ".nef",
            ".heic",
            ".avif",
            ".arw",
            ".dng",
            ".raf",
            ".mp4",
            ".webm",
            ".mov",
            ".avi",
            ".mkv",
            ".flv",
            ".wmv",
            ".m4v",
            ".mpeg",
            ".mpg",
            ".mp3",
            ".wav",
            ".ogg",
            ".flac",
            ".aac",
            ".wma",
            ".m4a",
            ".opus",
            ".ttf",
            ".otf",
            ".woff",
            ".woff2",
            ".eot",
            ".zip",
            ".tar",
            ".gz",
            ".rar",
            ".7z",
            ".bz2",
            ".xz",
            ".tgz",
            ".pyc",
            ".pyo",
            ".class",
            ".o",
            ".so",
            ".dll",
            ".exe",
            ".bin",
            ".wasm",
            ".a",
            ".lib",
            ".obj",
            ".pdf",
            ".doc",
            ".docx",
            ".xls",
            ".xlsx",
            ".ppt",
            ".pptx",
            ".sqlite",
            ".db",
            ".mdb",
            ".vhdx",
            ".vmdk",
            ".iso",
            ".dmg",
            ".deb",
            ".rpm",
            ".icns"
          ],
          "description": "File extensions considered binary for classification and binary-focused views."
        },
        "repoStats.locExcludedExtensions": {
          "type": "array",
          "scope": "resource",
          "default": [],
          "description": "File extensions to exclude from LOC counting (e.g. .svg). Accepts forms like .svg, svg, or **/*.svg."
        },
        "repoStats.bookmarkedRepositories": {
          "type": "array",
          "scope": "application",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Bookmarked Git repository paths shown in the repository selector even when they are outside the current workspace"
        },
        "repoStats.showEmptyTimePeriods": {
          "type": "boolean",
          "default": true,
          "description": "Show weeks/months with no activity in charts (displays true timeline gaps)"
        },
        "repoStats.defaultGranularityMode": {
          "type": "string",
          "enum": [
            "auto",
            "weekly",
            "monthly"
          ],
          "default": "auto",
          "description": "Default time granularity for charts. 'auto' switches based on repo history length."
        },
        "repoStats.autoGranularityThreshold": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 520,
          "description": "In 'auto' mode, use weekly view if repo has this many weeks or fewer, otherwise use monthly."
        },
        "repoStats.overviewDisplayMode": {
          "type": "string",
          "enum": [
            "percent",
            "count"
          ],
          "default": "percent",
          "description": "How to display values in the overview panel"
        },
        "repoStats.tooltipSettings": {
          "type": "object",
          "default": {
            "showLinesOfCode": true,
            "showFileSize": true,
            "showLanguage": true,
            "showLastModified": true,
            "showComplexity": false,
            "showCommentLines": false,
            "showCommentRatio": false,
            "showBlankLines": false,
            "showCodeDensity": false,
            "showFileCount": true
          },
          "description": "Configure which metrics to show in the treemap tooltip"
        },
        "repoStats.treemap.ageColorRangeMode": {
          "type": "string",
          "enum": [
            "auto",
            "custom"
          ],
          "default": "auto",
          "description": "How treemap age coloring chooses its green-to-red date range: automatically from the visible files or from custom settings"
        },
        "repoStats.treemap.ageColorNewestDate": {
          "type": "string",
          "default": "",
          "description": "Custom newest date (YYYY-MM-DD) at or after which treemap age coloring becomes fully green"
        },
        "repoStats.treemap.ageColorOldestDate": {
          "type": "string",
          "default": "",
          "description": "Custom oldest date (YYYY-MM-DD) at or before which treemap age coloring becomes fully red"
        },
        "repoStats.evolution.autoRun": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run Evolution analysis when opening the Evolution tab if cached data is missing or stale"
        },
        "repoStats.evolution.samplingMode": {
          "type": "string",
          "scope": "resource",
          "enum": [
            "time",
            "commit",
            "auto"
          ],
          "default": "auto",
          "description": "How Evolution selects snapshots: by elapsed time, by evenly spaced commit snapshots, or auto-distributed across history"
        },
        "repoStats.evolution.snapshotIntervalDays": {
          "type": "number",
          "scope": "resource",
          "default": 30,
          "minimum": 1,
          "maximum": 365,
          "description": "Minimum days between sampled snapshots when Evolution sampling mode is time-based"
        },
        "repoStats.evolution.showInactivePeriods": {
          "type": "boolean",
          "scope": "resource",
          "default": false,
          "description": "Whether Evolution charts should fill and display inactive periods between sampled snapshots"
        },
        "repoStats.evolution.maxSnapshots": {
          "type": "number",
          "scope": "resource",
          "default": 20,
          "minimum": 2,
          "maximum": 500,
          "description": "Target number of historical snapshots analyzed in Evolution. Commit and auto modes distribute snapshots across history to match this target; time mode uses it as a cap."
        },
        "repoStats.evolution.maxSeries": {
          "type": "number",
          "scope": "resource",
          "default": 20,
          "minimum": 5,
          "maximum": 200,
          "description": "Default maximum number of series shown in Evolution charts"
        },
        "repoStats.evolution.cohortFormat": {
          "type": "string",
          "scope": "resource",
          "default": "%Y",
          "description": "Cohort grouping format for Evolution analysis (%Y, %Y-%m, %Y-W%W)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run compile:extension && npm run compile:webview",
    "compile:extension": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "compile:webview": "cd webview-ui && npm run build",
    "compile:integration-tests": "tsc -p tsconfig.integration.json",
    "watch": "npm-run-all -p watch:*",
    "watch:extension": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "watch:webview": "cd webview-ui && npm run build:watch",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.tools.json",
    "typecheck:watch": "tsc --noEmit --watch",
    "lint": "eslint src webview-ui/src --ext ts,tsx",
    "lint:fix": "eslint src webview-ui/src --ext ts,tsx --fix",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest watch",
    "test:integration": "npm run compile:extension && npm run compile:integration-tests && vscode-test",
    "test:e2e": "extest setup-and-run './test/e2e/*.test.ts' --mocha_config .mocharc.json",
    "test:e2e:setup": "extest get-vscode && extest get-chromedriver",
    "test:coverage": "vitest run --coverage",
    "bench:analysis": "node ./tools/analysis_benchmark.js run",
    "bench:analysis:list": "node ./tools/analysis_benchmark.js list-targets",
    "bench:record": "./tools/benchmark_baseline.sh record",
    "bench:compare-prev": "./tools/benchmark_baseline.sh compare-prev",
    "bench:remote:check": "./tools/remote_benchmark_async.sh check",
    "validate": "npm run typecheck && npm run lint && npm run test && npm run package",
    "package": "node ./tools/package_vsix.js",
    "package:clean": "node ./tools/package_vsix.js --clean",
    "build": "npm run compile"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.6",
    "@types/node": "^25.x",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^3.7.1",
    "chai": "^6.2.2",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "jsdom": "^29.0.0",
    "npm-run-all": "^4.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18",
    "vscode-extension-tester": "^8.23.0"
  },
  "dependencies": {
    "simple-git": "^3.33.0"
  }
}
