# Remote benchmark configuration for VSCode-repo-stats
#
# Purpose:
# - run analysis benchmarks on a quieter remote machine for more comparable history
# - keep remote benchmark baselines separate from local ones
# - stage immutable per-run snapshots so later local edits cannot change the measured code
# - mirror remote .bench-results back into this repo under:
#     .bench-results/remotes/<machine-name>/
#
# Typical setup:
#   cp ./tools/remote_benchmark.env.example ./tools/remote_benchmark.env
#   # fill values below
#   ./tools/remote_benchmark_async.sh check
#   ./tools/remote_benchmark_async.sh start record
#   ./tools/remote_benchmark_async.sh wait "$(./tools/remote_benchmark_async.sh latest)"
#
# Required remote SSH target, for example:
#   REPO_STATS_REMOTE_SSH_TARGET=pi@raspi-bench
#   REPO_STATS_REMOTE_SSH_TARGET=ubuntu@my-tailnet-host
REPO_STATS_REMOTE_SSH_TARGET=

# Stable short machine label used to namespace mirrored results.
# Example: REPO_STATS_REMOTE_MACHINE_NAME=raspi4
REPO_STATS_REMOTE_MACHINE_NAME=

# Absolute remote staging directory.
# Example: REPO_STATS_REMOTE_STAGE_DIR=/home/pi/bench/vscode-repo-stats-stage
REPO_STATS_REMOTE_STAGE_DIR=

# Optional remote env file to source before npm/node commands.
# Useful when non-interactive SSH sessions do not automatically load nvm/asdf.
# Example: REPO_STATS_REMOTE_ENV_FILE=/home/pi/.nvm/nvm.sh
# REPO_STATS_REMOTE_ENV_FILE=

# Optional local override for the env file path itself.
# REPO_STATS_REMOTE_ENV_FILE_LOCAL=tools/remote_benchmark.env

# Optional tool overrides.
# REPO_STATS_REMOTE_SSH_BIN=ssh
# REPO_STATS_REMOTE_RSYNC_BIN=rsync
# REPO_STATS_REMOTE_RSYNC_SSH=ssh

# Optional idle-load gate.
# Benchmark jobs are always serialized behind a single remote lock.
# These settings add a best-effort quiet-machine check after the lock is acquired.
# Example for a mostly dedicated 4-core Pi:
#   REPO_STATS_REMOTE_BENCH_IDLE_MAX_LOAD1=1.0
#   REPO_STATS_REMOTE_BENCH_IDLE_POLL_SECONDS=30
#   REPO_STATS_REMOTE_BENCH_IDLE_STREAK=2
# REPO_STATS_REMOTE_BENCH_IDLE_MAX_LOAD1=
# REPO_STATS_REMOTE_BENCH_IDLE_POLL_SECONDS=30
# REPO_STATS_REMOTE_BENCH_IDLE_STREAK=1

# Optional wait poll interval for the local helper.
# REPO_STATS_REMOTE_BENCH_WAIT_POLL_SECONDS=10
